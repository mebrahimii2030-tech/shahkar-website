{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "shahkar-website",
  "compatibility_date": "2026-07-19",
  "main": "src/worker.js",

  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/panel-admin.html", "/panel-customer.html"]
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "shamkar-db",
      "database_id": "b3e72150-6858-4a63-ba8d-957a8808af01"
    }
  ]
}
